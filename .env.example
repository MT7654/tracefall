# Runtime mode: demo, hybrid, or live
TRACEFALL_MODE=hybrid

# Daytona
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Oxylabs Residential Proxies
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
OXYLABS_PROXY_URL=http://pr.oxylabs.io:7777

# Doubleword
DOUBLEWORD_API_KEY=
DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1
DOUBLEWORD_CHAT_MODEL=Qwen/Qwen3.5-35B-A3B-FP8
DOUBLEWORD_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# ai&
AIAND_API_KEY=
AIAND_BASE_URL=https://api.aiand.com/v1
AIAND_MODEL=moonshotai/kimi-k2.7-code

# Nosana
NOSANA_API_KEY=
NOSANA_API_BASE_URL=https://dashboard.k8s.prd.nos.ci/api
NOSANA_DEPLOYMENT_ID=
NOSANA_MODEL=qwen3.5:9b
NOSANA_INFERENCE_URL=

# Public URL used for Oxylabs regional checks after deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000
